# Environment variables for the wan-animate server.
# Copy to .env (or set in RunPod endpoint config) and adjust.

# Where Wan 2.2 Animate model weights live. Default matches the main
# replicate-local Network Volume layout so the same volume can host both.
WAN_CKPT_DIR=/runpod-volume/ComfyUI/models

# Where SAM2 model weights live (sam2_hiera_base_plus.safetensors etc.).
SAM2_CKPT_DIR=/runpod-volume/ComfyUI/models/sam2

# Where generated mp4s land. Same dir the main worker writes to so the
# downloader endpoint can fetch them.
OUTPUT_DIR=/runpod-volume/output/wan-animate

# HTTP port (only relevant when running as a Pod, not Serverless).
PORT=8000

# Hugging Face token (optional, only needed if setup_model.py is run inside
# the container instead of from a temp Pod with the volume mounted).
HF_TOKEN=
