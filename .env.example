# RunPod Serverless
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_TIMEOUT_SECONDS=600

# Local Qwen3-4B via Transformers + bitsandbytes 4-bit (in-process)
# Weights are downloaded from HuggingFace on first use and cached under
# %USERPROFILE%\.cache\huggingface\hub on Windows (~8 GB).
QWEN_MODEL_ID=Qwen/Qwen3-4B-Instruct-2507

# Storage
DATA_DIR=./data

# Frontend
FRONTEND_URL=http://localhost:3000
# (frontend uses) NEXT_PUBLIC_API_URL=http://localhost:8000
