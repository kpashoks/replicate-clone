# RunPod Serverless
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_TIMEOUT_SECONDS=600

# Optional companion Serverless endpoint that fetches non-image outputs
# (mp4 etc.) off the Network Volume. See runpod-downloader/README.md.
# Leave empty until you've deployed it.
RUNPOD_DOWNLOADER_ENDPOINT_ID=

# Local Qwen3-4B via Transformers + bitsandbytes 4-bit (in-process)
# Weights are downloaded from HuggingFace on first use and cached under
# %USERPROFILE%\.cache\huggingface\hub on Windows (~8 GB).
QWEN_MODEL_ID=Qwen/Qwen3-4B-Instruct-2507

# Wan 2.2 Animate dedicated server (see runpod-wan-animate/). HTTP base URL
# of the deployed Pod. Leave empty until deployed - the character-swap
# model card will fail with a clear error if missing.
# Example: https://abc123-8000.proxy.runpod.net
WAN_ANIMATE_ENDPOINT=
# Default 5400s (90 min). Rule of thumb on Blackwell GPU:
#   2s clip ~12 min, 5s ~25 min, 10s ~50 min, 15s ~75 min.
# Bump higher only if you submit longer clips.
WAN_ANIMATE_TIMEOUT_SECONDS=5400

# Atlas Cloud (https://atlascloud.ai). Unified inference aggregator used for
# hosted T2I / I2I models (FLUX.2 Pro, Imagen 4 Ultra, Qwen-Image Edit Plus,
# Nano Banana 2 Edit, GPT Image 2 Edit, Grok Imagine Edit, etc.). Leave key
# empty until you've signed up — models with provider="atlas" will fail at
# submit with "ATLAS_CLOUD_API_KEY is not set in .env".
ATLAS_CLOUD_API_KEY=
ATLAS_CLOUD_BASE_URL=https://api.atlascloud.ai
# Max wall-clock seconds the local backend will wait for an Atlas job.
# Observed: T2I/I2I 10-60s, T2V 30-120s, I2V 60-300s, V2V 180-900s.
# 1800s (30 min) covers v2v without timing out cheap image jobs.
ATLAS_TIMEOUT_SECONDS=1800

# Storage
DATA_DIR=./data

# Default destination folder for the "Save & Rename" feature on completed
# jobs. Leave empty to require the user to type a destination each time.
# Use a Windows-style absolute path on Windows, POSIX elsewhere. Supports
# ~ expansion. The folder is auto-created on first save if it doesn't
# exist (and the parent is writable). Examples:
#   DOWNLOAD_DIR=C:\Users\you\Pictures\replicate-out
#   DOWNLOAD_DIR=~/Pictures/replicate-out
DOWNLOAD_DIR=

# Frontend
FRONTEND_URL=http://localhost:3000
# (frontend uses) NEXT_PUBLIC_API_URL=http://localhost:8000
