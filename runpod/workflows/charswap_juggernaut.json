{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors"
    }
  },
  "2": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "user_input_character.png"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "user_input_source.png"
    }
  },
  "6": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["2", 0],
      "image": ["4", 0],
      "clip_vision": ["3", 0],
      "weight": "__IDENTITY_STRENGTH__",
      "weight_type": "style transfer",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "7": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["5", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024,
      "bbox_detector": "yolox_l.onnx",
      "pose_estimator": "dw-ll_ucoco_384_bs5.torchscript.pt"
    }
  },
  "8": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "controlnet-openpose-sdxl-xinsir.safetensors"
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__PROMPT__",
      "clip": ["1", 1]
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__",
      "clip": ["1", 1]
    }
  },
  "11": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["9", 0],
      "negative": ["10", 0],
      "control_net": ["8", 0],
      "image": ["7", 0],
      "strength": "__POSE_STRENGTH__",
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "12": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": ["20", 0],
      "height": ["20", 1],
      "batch_size": 1
    }
  },
  "20": {
    "class_type": "GetImageSize",
    "inputs": {
      "image": ["5", 0]
    }
  },
  "13": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["6", 0],
      "positive": ["11", 0],
      "negative": ["11", 1],
      "latent_image": ["12", 0],
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "14": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["13", 0],
      "vae": ["1", 2]
    }
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["14", 0],
      "filename_prefix": "__OUTPUT_PREFIX__"
    }
  },
  "30": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "__OUTPUT_PREFIX___debug_pose"
    }
  }
}
